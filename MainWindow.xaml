<Window x:Class="Dbt_Migrate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dbt_Migrate"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="760"
        Width="1024"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NewButton" TargetType="Button">
            <Setter Property="Background" Value="Red" />
            <Setter Property="Button.Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      Direction="320"
                                      ShadowDepth="3"
                                      BlurRadius="5"
                                      Opacity="0.5" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsPressed" Value="False" />
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="Green" />
                </MultiTrigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Button.Background" Value="Purple" />
                    <Setter Property="Button.Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Black"
                                              Direction="320"
                                              ShadowDepth="0"
                                              BlurRadius="0"
                                              Opacity="0" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="60" />
            <RowDefinition Height="30" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Start"
                       HorizontalAlignment="Left"
                       Height="25"
                       VerticalAlignment="Center"
                       Margin="15,12,5,10"
                       d:LayoutOverrides="Width" />

            <TextBox Grid.Column="1"
                     Margin="5,5,15,5"
                     x:Name="tbstart"
                     MinWidth="100"
                     Height="30"
                     HorizontalAlignment="Left"
                     d:LayoutOverrides="Width"
                     VerticalContentAlignment="Center" />

        </Grid>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <TextBlock Margin="15,12,5,10"
                       Text="End"
                       Width="100"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       d:LayoutOverrides="Width" />

            <TextBox x:Name="tbend"
                     Grid.Column="1"
                     Margin="5,5,15,5"
                     MinWidth="100"
                     Height="30"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center" />

        </Grid>


        <TextBlock Grid.Column="2"
                   Margin="15,10"
                   Text="Rapor Migrate Eki"
                   Width="100"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" />




        <StackPanel Grid.Row="2"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
            <ComboBox x:Name="urlValue"
                      Grid.Row="1"
                      Grid.Column="2"
                      Margin="5,5"
                      Width="190"
                      Height="30"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding Migrations}"
                      SelectedItem="{Binding SelectedMigration}"
                      IsEditable="True" />

            <Button Content=" ? "
                    Height="25"
                    VerticalAlignment="Center"
                    Click="GetMigrations_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Grid.Column="3"
                    Orientation="Horizontal">
            <TextBox Grid.Row="1"
                     Margin="15,5"
                     x:Name="femsql"
                     Width="150"
                     Height="30"
                     HorizontalAlignment="Left"
                     d:LayoutOverrides="Width"
                     VerticalContentAlignment="Center"
                     Visibility="Collapsed" />

            <Button Content=" Run FQ "
                    Height="25"
                    VerticalAlignment="Center"
                    Click="ExequteRunQl_Click"
                    Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock Text="Servis :"
                       Width="40"
                       Margin="10,15,5,5"
                       VerticalAlignment="Center"
                       Height="25"
                       HorizontalAlignment="Right"
                       d:LayoutOverrides="Width" />
            <ComboBox x:Name="cmbServis"
                      Width="130"
                      Height="25"
                      VerticalContentAlignment="Center">
                <ComboBox.Items>
                    <ComboBoxItem IsSelected="True">Pre Test</ComboBoxItem>
                    <ComboBoxItem>Test</ComboBoxItem>
                    <ComboBoxItem>Prod</ComboBoxItem>
                    <ComboBoxItem>Local</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
            <Button Content=" ? "
                    Height="25"
                    VerticalAlignment="Center"
                    Margin="3,2"
                    Click="GetDatNames_Click" />
        </StackPanel>

        <Button x:Name="btnTest"
                Grid.Row="1"
                Grid.Column="1"
                Content="Test"
                Click="TestButton_Click"
                Width="100"
                Margin="5,5">
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <StackPanel Grid.Row="1"
                    Grid.Column="2"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock Text="İşlem :"
                       Width="40"
                       Margin="10,11,5,5"
                       VerticalAlignment="Center"
                       Height="25"
                       HorizontalAlignment="Right"
                       d:LayoutOverrides="Width" />
            <ComboBox x:Name="cmbOperation"
                      Width="200"
                      Height="25"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cmbOperation_SelectionChanged">
                <ComboBox.Items>
                    <ComboBoxItem>0-Migrate</ComboBoxItem>
                    <ComboBoxItem>1-Dbt-Migrate</ComboBoxItem>
                    <ComboBoxItem>2-Function Renew</ComboBoxItem>
                    <ComboBoxItem>3-Run Sql</ComboBoxItem>
                    <ComboBoxItem>4-Check Migrate Id</ComboBoxItem>
                    <ComboBoxItem>5-Revert Migrate</ComboBoxItem>
                    <ComboBoxItem>6-Update SalerId</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>

            <Button Content=" ? "
                    Height="25"
                    VerticalAlignment="Center"
                    Margin="3,2"
                    Click="GetDatNames_Click" />

            <Button Content=" Çalıştır "
                    MinWidth="130"
                    Height="25"
                    VerticalAlignment="Center"
                    Margin="15,2"
                    Click="RunOperation_Click" />
        </StackPanel>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="4"
              Grid.RowSpan="2"
              x:Name="dbtMigrateGrid"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">

                <Button Content=" Get Dbt Migrations "
                        Margin="10,5"
                        Height="25"
                        VerticalAlignment="Center"
                        Click="GetMigrations_Click" />

                <TextBlock Text="Dbt Migrate Name"
                           HorizontalAlignment="Left"
                           Height="25"
                           VerticalAlignment="Center"
                           Margin="15,15,5,5"
                           d:LayoutOverrides="Width" />


                <ComboBox x:Name="cmbDbtMigrate"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="5,5"
                          Width="190"
                          Height="30"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding DbtMigrations}"
                          SelectedItem="{Binding SelectedDbtMigration}"
                          IsEditable="True" />

            </StackPanel>


        </Grid>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="4"
              Grid.RowSpan="2"
              x:Name="dbtFuncRenewGrid"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">

                <Button Content=" Get Functions "
                        Margin="10,5"
                        Height="25"
                        VerticalAlignment="Center" />

                <TextBlock Text="Function Name"
                           HorizontalAlignment="Left"
                           Height="25"
                           VerticalAlignment="Center"
                           Margin="15,15,5,5"
                           d:LayoutOverrides="Width" />


                <ComboBox x:Name="cmbFunctions"
                          Grid.Row="1"
                          Grid.Column="2"
                          Margin="5,5"
                          Width="230"
                          Height="30"
                          VerticalContentAlignment="Center"
                          IsEditable="True" />

            </StackPanel>


        </Grid>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="4"
              Grid.RowSpan="2"
              x:Name="grdUpdateSalerId"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">

                <TextBlock Text="Evrak Başlangıç Tarihi"
                           HorizontalAlignment="Left"
                           Height="25"
                           VerticalAlignment="Center"
                           Margin="15,15,5,5"
                           d:LayoutOverrides="Width" />

                <TextBox x:Name="docStartDate"
                         Grid.Column="1"
                         Margin="5,5,15,5"
                         MinWidth="100"
                         Height="30"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center" />

                <TextBlock Text="Evrak Bitiş Tarihi"
           HorizontalAlignment="Left"
           Height="25"
           VerticalAlignment="Center"
           Margin="15,15,5,5"
           d:LayoutOverrides="Width" />

                <TextBox x:Name="docEndDate"
         Grid.Column="1"
         Margin="5,5,15,5"
         MinWidth="100"
         Height="30"
         HorizontalAlignment="Left"
         VerticalContentAlignment="Center" />

            </StackPanel>


        </Grid>

        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal" />


        <Grid Grid.Row="3" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Button Content="Print-Reset"
                    Click="PrintReset_Click"
                    Width="100"
                    Margin="5,5"
                    Grid.Column="3"
                    Visibility="Collapsed">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>



            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <Button Content="Set-Function"
                        Width="100"
                        Margin="5,5"
                        Grid.Column="4"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="?"
                        VerticalAlignment="Center"
                        Margin="3,2"
                        Click="GetFuncNames_Click"
                        Visibility="Collapsed" />

            </StackPanel>


            <StackPanel Grid.Column="4"
                        Grid.Row="1"
                        Orientation="Horizontal">
                <Button Content="Update Companies"
                        Click="UpdateCompanies_Click"
                        Width="100"
                        Margin="5,5"
                        Grid.Column="4"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="?"
                        VerticalAlignment="Center"
                        Margin="3,2"
                        Click="GetFuncNames_Click"
                        Visibility="Collapsed" />

            </StackPanel>

            <Button Content="Clean UBL Info"
                    Grid.Column="5"
                    Width="110"
                    Click="CleanUblInfo_Click"
                    Margin="0,5"
                    Visibility="Collapsed" />

            <Button Content="Check Migration Id"
                    Click="CheckMigrationId_Click"
                    Width="110"
                    Margin="0,5"
                    Grid.Row="3"
                    Grid.Column="5"
                    Visibility="Collapsed">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Revert Migrate"
                    Click="RevertButton_Click"
                    Width="100"
                    Margin="5,5"
                    Grid.Row="3"
                    Grid.Column="6"
                    Visibility="Collapsed">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)" To="DodgerBlue" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </Grid>

        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="4"
                    VerticalAlignment="Center">
            <TextBlock Margin="15,2"
                       Text="{Binding Operation}"
                       VerticalAlignment="Center"
                       FontWeight="DemiBold"
                       Foreground="DeepSkyBlue" />
        </StackPanel>

        <Grid Grid.Row="5" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="2" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border BorderThickness="2"
                    BorderBrush="LimeGreen"
                    CornerRadius="5">
                <ListBox x:Name="list"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch" />
            </Border>

            <Border Grid.Column="2"
                    BorderThickness="2"
                    BorderBrush="red"
                    CornerRadius="5">
                <ListBox x:Name="errors"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         MouseDoubleClick="errors_MouseDoubleClick" />
            </Border>
        </Grid>



    </Grid>
</Window>
